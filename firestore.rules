rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Regra pública apenas para validação de conexão
    match /test/connection {
      allow read: if true;
    }

    // Regras de isolamento por usuário - Caminho Completo para Subcoleções
    match /users/{userId}/{documents=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Regra para o documento do usuário em si
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Negação global por segurança (deve estar por último)
    match /{document=**} {
      allow read, write: if false;
    }
  }
}

