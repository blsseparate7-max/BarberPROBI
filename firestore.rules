rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Regra pública para o caminho de teste
    match /test/connection {
      allow read: if true;
    }

    // Regras de isolamento total por UID
    // Permite leitura/escrita em qualquer documento ou subcoleção dentro de /users/{userId}
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
      
      match /{allPaths=**} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // Negação global (opcional mas recomendado)
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
