rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Negação global (Deny-by-default)
    match /{document=**} {
      allow read, write: if false;
    }

    // Permissão para o check de conectividade (Test Path)
    match /test/connection {
      allow read: if request.auth != null;
    }

    // Isolamento Profissional por UID
    // Garante que cada usuário acesse somente seus próprios dados sob /users/{userId}
    match /users/{userId}/{allPaths=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
