rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // 1. Caminho de Teste (Público para validação do SDK)
    match /test/connection {
      allow read: if true;
    }

    // 2. Espaço do Usuário (Recursivo)
    // Isso cobre /users/UID, /users/UID/profissionais, /users/UID/profissionais/DOC, etc.
    match /users/{userId}/{allPaths=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // 3. Documento raiz do usuário (Obrigatório para getDoc no nível users/UID)
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}

